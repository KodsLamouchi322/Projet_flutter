rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/membres/$(request.auth.uid)).data.role == 'admin';
    }
    function isAuth() { return request.auth != null; }

    match /livres/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /membres/{membreId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == membreId;
      allow update: if isAuth() && (request.auth.uid == membreId || isAdmin());
      allow delete: if isAdmin();
    }
    match /emprunts/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    match /reservations/{id} {
      allow read, write: if isAuth();
    }
    match /evenements/{id} {
      allow read: if true;
      allow write: if isAuth();
    }
    match /conversations/{convId} {
      allow read, write: if isAuth();
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }
    match /forum/{id} {
      allow read, write: if isAuth();
    }
    match /annonces/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /clubs_lecture/{clubId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAdmin();
      match /messages_club/{msgId} {
        allow read: if isAuth();
        allow create: if isAuth();
        allow delete: if isAdmin();
      }
    }
    
    // Nouvelles collections pour les clubs
    match /lectures_communes/{id} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    match /votes_livres/{id} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    match /defis_lecture/{id} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
    match /livres_club/{id} {
      allow read: if true;
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
  }
}
